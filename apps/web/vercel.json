{
  "crons": [
    {
      "path": "/api/cron/refresh-stats",
      "schedule": "*/15 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/status",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/og",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=3600" }
      ]
    }
  ]
}
